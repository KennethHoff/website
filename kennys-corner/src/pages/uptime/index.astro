---
import Layout from "@/components/layouts/Layout.astro";

const endpoints = [
    {name: "Linea - Test", url: "https://api-www-test.linea.no/health"},
    {name: "Tensio - Test", url: "https://api-www-test.tensio.no/health"},
    {name: "Linea - Prod", url: "https://api-www.linea.no/health"},
    {name: "Tensio - Prod", url: "https://api-www.tensio.no/health"},
    {name: "MS | Linea - Test", url: "https://api-minesaker-test.linea.no/health"},
    {name: "MS | Tensio - Test", url: "https://api-minesaker-test.tensio.no/health"},
    {name: "MS | Linea - Prod", url: "https://api-minesaker.linea.no/health"},
    {name: "MS | Tensio - Prod", url: "https://api-minesaker.tensio.no/health"},
];

const results = await Promise.all(endpoints.map(async endpoint => {
    const result = await fetch(endpoint.url);
    if (result.success) {
        return null;
    }
    return await {
        name: endpoint.name,
        text: result.text()
    }
}));

---

<Layout metadata={{
    title: "Uptime"
}}>
    <ul class="col-[content]">
        {results.map(x => {
        return <li>{x.name}: {x.text}</li>;
        })
    </ul>
</Layout>
